{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/cmake-build-${presetName}",
      "generator": "Ninja"
    },
    {
      "name": "debug-x86_64",
      "displayName": "Debug x86_64",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ZEP_ARCH": "x86_64",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_ASM_COMPILER": "clang"
      }
    },
    {
      "name": "debug-aarch64",
      "displayName": "Debug aarch64",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ZEP_ARCH": "aarch64",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_ASM_COMPILER": "clang"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug-x86_64", "configurePreset": "debug-x86_64" },
    { "name": "debug-aarch64", "configurePreset": "debug-aarch64" }
  ]
}
